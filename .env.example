# ==== StudyClaw Environment Values (Example) ====
# 版本: v0.1.0
# 复制此文件为 .env 并在本地补充真实凭据，此文件已预配置为本地开发环境的默认值。
# 请勿将带有真实敏感信息的 .env 文件提交到版本控制！

# [Database] - 当前 v0.1.0 原型未启用数据库，保留为后续迁移预留
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=studyclaw_dev_secret
DB_NAME=studyclaw_dev

# [Redis] - 本地 Docker 默认配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# [Agent Core / LLM] - 需要您手动填写真实的 API Key
# 兼容 OpenAI 格式的 Provider (如: openai, deepseek, moonshot, qwen)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-actual-api-key-here

# [Services] - 端口映射
API_PORT=8080
AGENT_PORT=8000
AGENT_CORE_URL=http://localhost:8000
STUDYCLAW_DATA_DIR=./data
