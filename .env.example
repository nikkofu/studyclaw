# ==== StudyClaw Environment Values (Example) ====
# 版本: v0.2.0
# 此文件只保留可公开的模板与本地默认值，真实账号与密钥请放到仓库外。
# 推荐路径: ~/.config/studyclaw/runtime.env
# 也可通过 STUDYCLAW_ENV_FILE=/absolute/path/to/runtime.env 显式指定。
# 请勿将带有真实敏感信息的 .env 或 runtime.env 文件提交到版本控制！

# [Database] - 当前 v0.2.0 交付基线未启用数据库，保留为后续迁移预留
# 如果未来启用数据库，生产账号不要复用个人账号，建议为每个环境单独分配服务账号
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace-in-private-runtime-env
DB_PASSWORD=replace-in-private-runtime-env
DB_NAME=studyclaw_dev

# [Redis] - 本地 Docker 默认配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# [LLM] - 默认按字节火山 Ark 的 OpenAI 兼容接口配置
# 真实 Key 只应出现在仓库外的 runtime.env 中，前端与移动端不得持有此 Key
LLM_PROVIDER=ark
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your-ark-api-key-here
LLM_MODEL_NAME=your-ark-model-name-here
# 可选: 为不同能力单独指定模型，不填则回退到 LLM_MODEL_NAME
# LLM_PARSER_MODEL_NAME=
# LLM_GRADER_MODEL_NAME=
# LLM_WEEKLY_MODEL_NAME=
# LLM_HTTP_TIMEOUT_SECONDS=90

# [Services] - 当前 Go 后端运行参数
API_PORT=8080
STUDYCLAW_DATA_DIR=./data
# STUDYCLAW_LOG_DIR=./data/logs
